% ============================================================
%  sd_style.sty — Schola Domestica Mathematics Shared Style
%  Place in: curriculum/Level-1/
%  Usage in each lesson: \usepackage{../../sd_style}
%  Requires XeLaTeX
% ============================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{sd_style}[2026/05/30 Schola Domestica Mathematics Style]

% ── Packages ────────────────────────────────────────────────
\usepackage[top=1in, bottom=1in, left=1in, right=1in]{geometry}
\usepackage{fontspec}
\usepackage{graphicx}
\usepackage{array}
\usepackage{tabularx}
\usepackage{multicol}
\usepackage{tikz}
\usetikzlibrary{shapes.geometric, calc}
\usepackage{xcolor}
\usepackage{amssymb}
\usepackage{amsmath}
\usepackage{mdframed}
\usepackage{parskip}
\usepackage{microtype}
\usepackage{fancyhdr}

% ── Fonts ────────────────────────────────────────────────────
\setmainfont{EB Garamond}[Ligatures=TeX, Numbers=OldStyle]

% ── Colors ───────────────────────────────────────────────────
\definecolor{sd-blue}{RGB}{60, 100, 160}
\definecolor{sd-gold}{RGB}{180, 140, 50}
\definecolor{sd-light}{RGB}{245, 242, 235}
\definecolor{sd-green}{RGB}{70, 130, 80}

% ── Page Style ───────────────────────────────────────────────
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0.4pt}
\fancyhead[L]{\small\color{sd-blue}\textit{Schola Domestica Mathematics}}
\fancyhead[R]{\small\color{sd-blue}\textit{Level~1 \(\cdot\) Week~\lessonweek\ \(\cdot\) Lesson~\lessonnum}}
\fancyfoot[C]{\small\color{sd-blue}\thepage}

% ── Lesson Metadata Macros (override in each file) ───────────
\newcommand{\lessonnum}{1}
\newcommand{\lessonweek}{1}
\newcommand{\lessontitle}{Lesson Title}

% ── Answer Blank ─────────────────────────────────────────────
\newcommand{\ansblank}{\underline{\hspace{1.6cm}}}
\newcommand{\ansblanklg}{\underline{\hspace{2.2cm}}}

% ── Problem Counter ──────────────────────────────────────────
\newcounter{probnum}
\newcommand{\prob}{\stepcounter{probnum}\noindent\textbf{\arabic{probnum}.}\quad}

% ── Framed Environments ──────────────────────────────────────
\newmdenv[
  backgroundcolor=sd-light, linecolor=sd-blue, linewidth=1pt,
  innerleftmargin=10pt, innerrightmargin=10pt,
  innertopmargin=8pt, innerbottommargin=8pt, roundcorner=4pt
]{instructbox}

\newmdenv[
  backgroundcolor=white, linecolor=sd-green, linewidth=1.5pt,
  innerleftmargin=10pt, innerrightmargin=10pt,
  innertopmargin=8pt, innerbottommargin=8pt, roundcorner=4pt
]{checkbox}

% ── TikZ Shape Macros ────────────────────────────────────────
\newcommand{\onestar}{%
  \begin{tikzpicture}[baseline=-0.1cm]
    \node[star, star points=5, star point ratio=2.5,
          fill=sd-gold, draw=sd-gold!80!black, minimum size=0.9cm]{};
  \end{tikzpicture}}

\newcommand{\onedot}{%
  \begin{tikzpicture}[baseline=-0.05cm]
    \fill[sd-blue](0,0)circle(0.22cm);
  \end{tikzpicture}}

\newcommand{\onecircle}{%
  \begin{tikzpicture}[baseline=-0.05cm]
    \draw[sd-blue, thick](0,0)circle(0.22cm);
  \end{tikzpicture}}

% ── Lesson Header Macro ──────────────────────────────────────
% Usage: \lessonheader{Week N}{Lesson N}{Title}
\newcommand{\lessonheader}[3]{%
  \begin{center}
    {\color{sd-blue}\Large\bfseries Schola Domestica Mathematics — Level~1}\\[4pt]
    {\color{sd-blue}\rule{\linewidth}{1.5pt}}\\[6pt]
    {\LARGE\bfseries Lesson~#2 \quad|\quad #3}\\[4pt]
    {\color{sd-gold}\rule{\linewidth}{0.8pt}}
  \end{center}
  \vspace{4pt}}

% ── Gold Rule ────────────────────────────────────────────────
\newcommand{\goldrule}{\vspace{6pt}{\color{sd-gold}\rule{\linewidth}{0.5pt}}\vspace{6pt}}

% ── Trace Row Macro ──────────────────────────────────────────
% Usage: \tracerow{digit1}{digit2}  (pass {} for single digit)
\newcommand{\tracerowone}[1]{%
  \begin{center}
  \begin{tabular}{|c|c|c|c|c|}
  \hline
  \rule{0pt}{26pt}{\Huge\color{sd-blue!40}#1}&{\Huge\phantom{#1}}&{\Huge\phantom{#1}}&{\Huge\phantom{#1}}&{\Huge\phantom{#1}}\\
  \hline
  \end{tabular}
  \end{center}}

\newcommand{\tracerowpair}[2]{%
  \begin{center}
  \begin{tabular}{|c|c|c|c|c|c|c|c|}
  \hline
  \rule{0pt}{26pt}{\Huge\color{sd-blue!40}#1}&{\Huge\phantom{#1}}&{\Huge\phantom{#1}}&{\Huge\phantom{#1}}&%
  {\Huge\color{sd-blue!40}#2}&{\Huge\phantom{#2}}&{\Huge\phantom{#2}}&{\Huge\phantom{#2}}\\
  \hline
  \end{tabular}
  \end{center}}
